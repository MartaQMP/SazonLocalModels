<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>True</GeneratePackageOnBuild>
    <PackageId>sazonLocal.Models</PackageId>
    <Title>SazonLocal.Models</Title>
    <Authors>Marta</Authors>
    <PackageIcon>Logo_Sazon_Local.png</PackageIcon>
    <PackageTags>sazonlocal;sazon;local;model;models</PackageTags>
    <Version>1.4.2</Version>
  </PropertyGroup>

  <ItemGroup>
    <None Remove="Logo_Sazon_Local.png" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="Logo_Sazon_Local.png">
      <Pack>True</Pack>
      <PackagePath>\</PackagePath>
    </EmbeddedResource>
  </ItemGroup>

</Project>
